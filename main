import pandas as pd
import matplotlib.pyplot as plt

from sklearn.model_selection import train_test_split
from sklearn.tree import DecisionTreeClassifier, plot_tree
from sklearn.metrics import accuracy_score
from sklearn.metrics import confusion_matrix, ConfusionMatrixDisplay

# Dataset
url = "https://raw.githubusercontent.com/aniruddhachoudhury/Red-Wine-Quality/master/winequality-red.csv"

# Ler CSV
df = pd.read_csv(url)
df = df.rename(columns={
    "fixed acidity": "acidez fixa",
    "volatile acidity": "acidez volátil",
    "citric acid": "ácido cítrico",
    "residual sugar": "açúcar residual",
    "chlorides": "cloretos",
    "free sulfur dioxide": "dióxido de enxofre livre",
    "total sulfur dioxide": "dióxido de enxofre total",
    "density": "densidade",
    "pH": "pH",
    "sulphates": "sulfatos",
    "alcohol": "álcool",
    "quality": "qualidade"
})

# Transformar qualidade em binário
df["qualidade"] = (df["qualidade"] >= 6).astype(int)

# Variáveis
X = df.drop("qualidade", axis=1)
y = df["qualidade"]

# Dividir treino e teste
X_train, X_test, y_train, y_test = train_test_split(
    X,
    y,
    test_size=0.3,
    random_state=42
)

# Criar modelo
modelo = DecisionTreeClassifier(
    max_depth=4,
    random_state=42
)
# Treinar
modelo.fit(X_train, y_train)

# Fazer previsões
y_pred = modelo.predict(X_test)

# Acurácia
acc = accuracy_score(y_test, y_pred)

print(f"Acurácia: {acc:.2f}")

# Matriz de confusão
matriz = confusion_matrix(y_test, y_pred)

disp = ConfusionMatrixDisplay(
    confusion_matrix=matriz,
    display_labels=["Ruim", "Bom"]
)

fig, ax = plt.subplots(figsize=(7,6))

disp.plot(cmap="viridis", ax=ax)

plt.title("Matriz de Confusão")

# Legenda fora do gráfico
legenda = (
    "VN = Verdadeiro Negativo\n"
    "FP = Falso Positivo\n"
    "FN = Falso Negativo\n"
    "VP = Verdadeiro Positivo"
)

plt.figtext(
    0.92, 0.5,
    legenda,
    fontsize=10,
    va='center'
)

plt.savefig(
    "matriz_confusao.png",
    bbox_inches='tight'
)
plt.show()

# Árvore de decisão
plt.figure(figsize=(18,12), dpi=200)

plot_tree(
    modelo,
    filled=True,
    feature_names=X.columns,
    class_names=["Ruim", "Bom"],
    rounded=True,
    fontsize=4
)

plt.tight_layout()

plt.savefig(
    "arvore_decisao.png",
    bbox_inches='tight'
)

plt.show()

# Importância das variáveis
importancias = modelo.feature_importances_

plt.figure(figsize=(10,6))

plt.barh(X.columns, importancias)
plt.grid(axis='x')
plt.title("Importância das Variáveis")

plt.xlabel("Importância")

plt.savefig(
    "importancia_variaveis.png",
    bbox_inches='tight'
)

plt.show()
